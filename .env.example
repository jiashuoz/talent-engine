# Local development DB. Docker compose / Aliyun / Cloud SQL override this.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent_engine

# Cloud SQL (production on GCP). Mutually exclusive with DATABASE_URL.
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=talent_engine

# LLM — Gemini via Vertex (preferred) with Google AI Studio fallback.
# For mainland China deployment, swap the BAML client to a domestic model
# (Qwen, Doubao, etc.) — see baml_src/main.baml.
GOOGLE_CLOUD_PROJECT=
GEMINI_API_KEY=

# Usage notification email (Resend). Fire-and-forget; failures don't break runs.
RESEND_API_KEY=
USAGE_NOTIFY_TO=

# CORS allowlist. Comma-separated. Default "*" is fine for dev.
CORS_ORIGINS=*
