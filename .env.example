# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Postgres password used by docker-compose (for both the `db` service and
# the `DATABASE_URL` constructed at runtime). Set to a strong random value
# before first `docker compose up`. Required by docker-compose.yml.
POSTGRES_PASSWORD=changeme

# Explicit DATABASE_URL overrides the docker-compose default. Use when
# running the API outside compose (against a local Postgres or a managed
# DB like UCloud UDB / TencentDB).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent_engine
# DATABASE_URL=postgresql://user:pass@10.x.x.x:5432/talent_engine

# Production (legacy): GCP Cloud SQL Unix socket. Mutually exclusive with
# DATABASE_URL — kept for the historical Cloud Run path.
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=talent_engine

# ---------------------------------------------------------------------------
# LLM provider — choose ONE and supply only its credentials.
# ---------------------------------------------------------------------------

# Which BAML client to route through. Must match a client name in
# api/v1/resume_matching/baml_src/main.baml. Unknown values fail loud at
# resolution time (ValueError on first request) — see llm_config.py.
#   Gemini    — original (Vertex AI primary, Google AI Studio fallback)
#   Qwen      — Aliyun DashScope OpenAI-compatible
#   Hunyuan   — Tencent OpenAI-compatible
#   DeepSeek  — text-only, low cost
LLM_PROVIDER=Gemini

# Gemini (only needed if LLM_PROVIDER=Gemini)
GOOGLE_CLOUD_PROJECT=
GEMINI_API_KEY=

# Qwen / DashScope (only needed if LLM_PROVIDER=Qwen)
QWEN_API_KEY=

# Hunyuan (only needed if LLM_PROVIDER=Hunyuan)
HUNYUAN_API_KEY=

# DeepSeek (only needed if LLM_PROVIDER=DeepSeek)
DEEPSEEK_API_KEY=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Listen port. Tencent CloudBase / Cloud Run / Aliyun FC inject this
# automatically; set explicitly for local docker-compose if needed.
PORT=8000

# CORS allowlist. Comma-separated. Default "*" is fine for dev.
CORS_ORIGINS=*
